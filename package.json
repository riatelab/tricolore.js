{
  "name": "tricolore",
  "version": "0.2.0",
  "description": "Color scale for ternary compositions",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "browser": "dist/index.umd.js",
  "exports": {
    "import": "./dist/index.esm.js",
    "require": "./dist/index.cjs.js",
    "default": "./dist/index.umd.js"
  },
  "types": "dist/types/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "jest",
    "lint": "eslint --ext .ts src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "docs": "typedoc",
    "prepublish": "# npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "visualization",
    "ternary",
    "choropleth",
    "maps",
    "composition"
  ],
  "author": {
    "name": "Matthieu Viry",
    "email": "matthieu.viry@cnrs.fr"
  },
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riatelab/tricolore.js.git"
  },
  "bugs": {
    "url": "https://github.com/riatelab/tricolore.js/issues"
  },
  "homepage": "https://github.com/riatelab/tricolore.js#readme",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "prettier": "^3.9.3",
    "rollup": "^4.62.2",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-license": "^3.7.1",
    "rollup-plugin-typescript2": "^0.37.0",
    "ts-jest": "^29.4.11",
    "typedoc": "^0.28.19",
    "typedoc-plugin-missing-exports": "^4.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
